{
    "name": "jantvrdik/webauthn",
    "description": "Spec-compliant WebAuthn (passkeys) library for PHP with minimal dependencies",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.2",
        "shipmonk/coverage-guard": "^1.0",
        "shipmonk/dead-code-detector": "^1.3",
        "phpstan/phpstan-strict-rules": "^2.0",
        "shipmonk/phpstan-rules": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "WebAuthnX\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebAuthnXTests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests",
        "phpstan": "phpstan analyse",
        "coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "phpunit tests --coverage-clover=clover.xml",
            "coverage-guard check clover.xml"
        ]
    }
}
