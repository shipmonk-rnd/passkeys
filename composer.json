{
    "name": "shipmonk/passkeys",
    "description": "Passkeys (WebAuthn) library for PHP with zero dependencies",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-openssl": "*"
    },
    "require-dev": {
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ergebnis/composer-normalize": "^2.52",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0",
        "shipmonk/coding-standard": "^0.3.0",
        "shipmonk/coverage-guard": "^1.0",
        "shipmonk/dead-code-detector": "^1.3",
        "shipmonk/phpstan-rules": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "ShipMonk\\Passkeys\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ShipMonk\\PasskeysTests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        }
    },
    "scripts": {
        "check": [
            "@check:composer",
            "@check:cs",
            "@check:types",
            "@check:coverage"
        ],
        "check:composer": [
            "composer normalize --dry-run --no-update-lock",
            "composer validate --strict"
        ],
        "check:coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "phpunit tests --coverage-clover cache/clover.xml",
            "coverage-guard check cache/clover.xml"
        ],
        "check:cs": "phpcs",
        "check:tests": "phpunit",
        "check:types": "phpstan analyse -vv --ansi",
        "fix:cs": "phpcbf"
    }
}
