<?xml version="1.0"?>
<ruleset
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="vendor/squizlabs/php_codesniffer/phpcs.xsd"
>
    <arg name="basepath" value="."/>
    <arg name="cache" value="cache/phpcs.cache"/>

    <file>example/</file>
    <file>src/</file>
    <file>tests/</file>

    <rule ref="ShipMonkCodingStandard">
        <!-- line-comment section dividers above functions are used throughout -->
        <exclude name="Squiz.Commenting.FunctionComment.WrongStyle"/>
        <!-- COSE algorithm constants follow spec names (EdDSA, Ed25519, Ed448) -->
        <exclude name="Generic.NamingConventions.UpperCaseConstantName"/>
        <!-- example/server.php is deliberately a flat single-file script -->
        <exclude name="Squiz.Functions.GlobalFunction"/>
    </rule>

    <!-- align @param annotations to columns; severity must be restored explicitly because ShipMonkCodingStandard excludes these codes -->
    <rule ref="Squiz.Commenting.FunctionComment.SpacingAfterParamType">
        <severity>5</severity>
    </rule>
    <rule ref="Squiz.Commenting.FunctionComment.SpacingAfterParamName">
        <severity>5</severity>
    </rule>
    <rule ref="SlevomatCodingStandard.Whitespaces.DuplicateSpaces">
        <properties>
            <property name="ignoreSpacesInAnnotation" value="true"/>
        </properties>
    </rule>
</ruleset>
